exec chainlink node db preparetest --help
cmp stdout out.txt
! stderr .

-- out.txt --
NAME:
   chainlink node db preparetest - Reset database and load fixtures.

USAGE:
   chainlink node db preparetest [command options] [arguments...]

OPTIONS:
   --user-only  only include test user fixture
   --force      legacy flag (ignored for drop); reset uses DROP DATABASE ... WITH (FORCE) (PostgreSQL 13+)
   
